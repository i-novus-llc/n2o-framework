{
  "name": "@i-novus/n2o-components",
  "version": "7.29.18",
  "description": "UI components for N2O framework",
  "author": "I-Novus LLC<n2o@i-novus.ru>",
  "license": "Apache-2.0",
  "homepage": "https://n2o.i-novus.ru/",
  "repository": {
    "type": "git",
    "url": "git@github.com:i-novus-llc/n2o-framework.git",
    "directory": "frontend/n2o-components"
  },
  "main": "lib/index.js",
  "files": [
    "lib",
    "index.js"
  ],
  "keywords": [
    "react",
    "components",
    "ui"
  ],
  "scripts": {
    "build": "yarn run clean:lib && tsc && yarn run copyfiles",
    "copyfiles": "copyfiles -u 2 src/styles/**/* src/styles/variables.scss src/styles/root.scss lib/styles",
    "clean:lib": "rimraf ./lib/",
    "clean": "yarn run clean:lib && rimraf ./node_modules/",
    "dev": "concurrently \"yarn run dev:lib\" \"yarn run dev:styles\"",
    "dev:styles": "chokidar \"src/styles/**/*\" -c \"yarn run copyfiles\"",
    "dev:lib": "tsc --watch",
    "eslint": "eslint --ext .js,.jsx,.ts,.tsx ./src",
    "eslint:fix": "eslint --ext .js,.jsx,.ts,.tsx --fix ./src",
    "stylelint": "stylelint ./src/**/*{.css,.scss,.sass}",
    "stylelint:fix": "stylelint --fix ./src/**/*{.css,.scss,.sass}",
    "lint": "yarn eslint && yarn stylelint"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.13",
    "@fontsource/exo-2": "^4.3.0",
    "@fortawesome/fontawesome-free": "^6.4.2",
    "@fortawesome/fontawesome-svg-core": "^6.4.2",
    "@fortawesome/free-solid-svg-icons": "^6.4.2",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@maskito/core": "3.8.0",
    "@maskito/kit": "3.8.0",
    "@maskito/react": "3.8.0",
    "bootstrap": "~4.3.1",
    "brace": "0.11.1",
    "classnames": "^2.3.1",
    "dompurify": "^3.3.1",
    "draft-js": "0.11.7",
    "draftjs-to-html": "0.8.4",
    "font-awesome": "4.7.0",
    "html-to-draftjs": "^1.4.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.2",
    "numeral": "2.0.6",
    "rc-drawer": "^3.0.2",
    "rc-slider": "^8.6.11",
    "rc-switch": "4.1.0",
    "rc-tree-select": "^5.27.0",
    "react-ace": "11.0.1",
    "react-copy-to-clipboard": "^5.0.1",
    "react-draft-wysiwyg": "1.15.0",
    "react-i18next": "14.1.2",
    "react-onclickoutside": "^6.13.2",
    "react-popper": "2.3.0",
    "react-router-dom": "5.2.0",
    "react-syntax-highlighter": "^15.5.0",
    "reactstrap": "8.10.1-popper2-beta.0",
    "scroll-into-view-if-needed": "2.2.26"
  },
  "peerDependencies": {
    "dayjs": "*",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0"
  },
  "devDependencies": {
    "@i-novus/eslint-config": "^1.0.19",
    "@types/classnames": "^2.3.1",
    "@types/draftjs-to-html": "0.8.1",
    "@types/html-to-draftjs": "^1.4.0",
    "@types/lodash": "^4.14.182",
    "@types/numeral": "^2.0.2",
    "@types/rc-slider": "8.6.6",
    "@types/rc-switch": "1.9.2",
    "@types/react-copy-to-clipboard": "^5.0.4",
    "@types/react-dom": "18.3.0",
    "@types/react-draft-wysiwyg": "1.13.7",
    "@types/react-onclickoutside": "^6.7.10",
    "@types/react-router-dom": "5.3.3",
    "@types/react-scroll-into-view-if-needed": "2.1.1",
    "@types/react-syntax-highlighter": "15.5.6",
    "@typescript-eslint/eslint-plugin": "^5.28.0",
    "@typescript-eslint/parser": "^5.27.1",
    "chokidar-cli": "^3.0.0",
    "concurrently": "10.0.3",
    "copyfiles": "^2.4.1",
    "eslint": "8.57.0",
    "rimraf": "5.0.7",
    "stylelint": "^13.12.0",
    "stylelint-config-standard": "^21.0.0",
    "stylelint-order": "^4.1.0",
    "stylelint-scss": "^3.19.0",
    "typescript": "4.7.3"
  },
  "engines": {
    "node": "20.x || 22.x"
  }
}
