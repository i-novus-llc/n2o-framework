<?xml version="1.0" encoding="UTF-8"?>
<page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
    name="Связь Master Detail">
    <datasources>
        <datasource id="ds1" query-id="test"/>
        <datasource id="ds2" query-id="test">
            <dependencies>
                <fetch model="resolve" on="ds1"/>
            </dependencies>
            <filters>
                <eq
                    datasource="ds1"
                    field-id="id"
                    required="true"
                    value="{id}"
                />
            </filters>
        </datasource>
    </datasources>
    <regions>
        <row>
            <col size="6">
                <table datasource="ds1">
                    <columns>
                        <column text-field-id="id"/>
                        <column text-field-id="name"/>
                    </columns>
                </table>
            </col>
            <col size="6">
                <form datasource="ds2">
                    <fields>
                        <input-text enabled="false" id="id"/>
                        <input-text enabled="false" id="name"/>
                    </fields>
                </form>
            </col>
        </row>
    </regions>
</page>