<?xml version='1.0' encoding='UTF-8'?>
<simple-page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
             name="Срабатывание по условию fetch и fetch-value зависимостей поля">
    <form>
        <fields>
            <input-text id="type" placeholder="Введите 1, затем 2" domain="integer"/>

            <input-text id="name" label="Должно обновиться при type &gt; 1">
                <dependencies>
                    <fetch-value on="type" apply-on-init="false" query-id="test"
                                 value-field-id="name" enabled="{type &gt; 1}">
                        <filters>
                            <eq field-id="id" value="{type}"/>
                        </filters>
                    </fetch-value>
                </dependencies>
            </input-text>

            <checkbox-group id="checkbox" label="Должно обновиться при type &gt; 1"
                            query-id="test">
                <filters>
                    <eq field-id="type" value="{type}"/>
                </filters>
                <dependencies>
                    <fetch on="type" enabled="{type &gt; 1}"/>
                </dependencies>
            </checkbox-group>
        </fields>
    </form>
</simple-page>