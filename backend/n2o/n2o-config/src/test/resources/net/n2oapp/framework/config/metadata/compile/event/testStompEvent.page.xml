<?xml version='1.0' encoding='UTF-8'?>
<page xmlns="http://n2oapp.net/framework/config/schema/page-4.0">
    <datasources>
        <datasource id="ds1"/>
    </datasources>

    <events>
        <stomp-event id="notif1" destination="/notifications">
            <alert title="{title}" text="{text}"/>
        </stomp-event>
        <stomp-event destination="/updates">
            <set-value target-datasource="ds1" target-model="resolve" to="{targetField}">
                return payload.value
            </set-value>
        </stomp-event>
    </events>
</page>
