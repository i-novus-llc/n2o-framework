<?xml version='1.0' encoding='UTF-8'?>
<page xmlns="http://n2oapp.net/framework/config/schema/page-4.0">
    <datasources>
        <datasource id="ds"/>
    </datasources>
    <regions>
        <form>
            <actions>
                <action id="act1">
                    <a href="http://ya.ru" target="self"/>
                </action>
            </actions>
            <fields>
                <hidden id="url" default-value="https://example.com"/>
                <button id="btn1" badge="{badge}" badge-color="{color}" label="delete"
                        color="{name}" datasource="ds">
                    <a href="/test2/:param1/:param2?param3=:param3">
                        <path-param name="param1" value="{field1}"/>
                        <path-param name="param2" value="1"/>
                        <query-param name="param3" value="{field3}"/>
                    </a>
                    <dependencies>
                        <enabling on="url" message="test message">test == null</enabling>
                    </dependencies>
                </button>
                <button id="btn2" action-id="act1" icon="fa fa-pencil" rounded="true"/>
                <button id="btn3" label="load" icon="{check ? 'fa fa-plus' : 'fa fa-minus'}"/>
                <button id="btn4">
                    <show-modal page-id="test" route="/test2/:param1/:param2?param3=:param3">
                        <params>
                            <path-param name="param1" value="{field1}"/>
                            <path-param name="param2" value="1"/>
                            <query-param name="param3" value="{field3}"/>
                        </params>
                    </show-modal>
                </button>
                <button id="btn5">
                    <a href="{url}" target="self"/>
                </button>
                <button
                        id="btn6"
                        description="{description}">
                </button>
                <button id="btn7" datasource="table">
                    <confirm/>
                    <a href="http://ya.ru" target="self"/>
                </button>
                <button id="btn8">
                    <confirm title="Предупреждение" text="Подтвердите действие" type="popover">
                        <ok label="Да" color="danger"/>
                        <cancel label="Нет" color="primary"/>
                    </confirm>
                </button>
                <hidden id="description" default-value="test"/>
            </fields>
        </form>
    </regions>
</page>
