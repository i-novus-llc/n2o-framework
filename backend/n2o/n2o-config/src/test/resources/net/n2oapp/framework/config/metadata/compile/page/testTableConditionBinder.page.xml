<?xml version='1.0' encoding='UTF-8'?>
<simple-page xmlns="http://n2oapp.net/framework/config/schema/page-4.0">
    <table>
        <datasource query-id="testEmptyBody"/>
        <dependencies>
            <visibility>status == #{ctxParam}</visibility>
            <enabling>status == #{ctxParam}</enabling>
        </dependencies>
        <toolbar place="topLeft">
            <button id="btn">
                <close/>
                <dependencies>
                    <visibility>status == #{ctxParam}</visibility>
                </dependencies>
            </button>
        </toolbar>
        <columns>
            <column text-field-id="name">
                <dependencies>
                    <visibility model="resolve">status == #{ctxParam}</visibility>
                </dependencies>
            </column>
            <dnd-column move-mode="settings">
                <column text-field-id="type">
                    <dependencies>
                        <visibility model="resolve">status == #{ctxParam}</visibility>
                    </dependencies>
                </column>
            </dnd-column>
        </columns>
    </table>
</simple-page>
