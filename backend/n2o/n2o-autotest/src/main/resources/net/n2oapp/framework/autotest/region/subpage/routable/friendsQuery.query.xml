<?xml version='1.0' encoding='UTF-8'?>
<query xmlns="http://n2oapp.net/framework/config/schema/query-5.0">
    <list>
        <test file="friends.json" operation="findAll"/>
    </list>

    <count>
        <test file="friends.json" operation="count"/>
    </count>

    <filters>
        <like field-id="city" filter-id="city"/>
    </filters>

    <fields>
        <field id="id"/>
        <field id="name"/>
        <field id="city" sorting="true"/>
        <field id="age"/>
    </fields>
</query>