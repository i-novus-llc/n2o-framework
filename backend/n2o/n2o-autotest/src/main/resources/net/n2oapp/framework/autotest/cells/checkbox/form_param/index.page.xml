<?xml version='1.0' encoding='UTF-8'?>
<simple-page xmlns="http://n2oapp.net/framework/config/schema/page-4.0" name="Автотест ячеек таблицы с form-param">
    <table>
        <datasource id="ds" query-id="data" object-id="data"/>
        <columns>
            <column text-field-id="id"/>
            <column id="check" label="check">
                <checkbox>
                    <invoke operation-id="update"
                        refresh-datasource="ds"
                        refresh-on-success="true"
                        message-on-success="false">
                        <form-param id="formParam"
                            value="{id}"
                            datasource="ds"
                            model="resolve"/>
                    </invoke>
                    <alert text="{formParam}"/>
                </checkbox>
            </column>
        </columns>
    </table>
</simple-page>