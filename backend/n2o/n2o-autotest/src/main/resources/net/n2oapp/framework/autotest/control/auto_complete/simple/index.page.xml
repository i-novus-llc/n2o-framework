<?xml version='1.0' encoding='UTF-8'?>
<simple-page xmlns="http://n2oapp.net/framework/config/schema/page-4.0">
    <form>
        <fields>
            <auto-complete id="autoComplete1" label="AutoComplete1" search-side="client">
                <options>
                    <option name="aaa"/>
                    <option name="abc"/>
                    <option name="ccc"/>
                </options>
            </auto-complete>
            <auto-complete id="autoComplete2" label="AutoComplete2" search-side="client">
                <options>
                    <option name="aaa"/>
                    <option name="abc"/>
                </options>
            </auto-complete>
            <auto-complete id="autoComplete3" query-id="test"
                           value-field-id="id" label-field-id="fio" search-filter-id="fio"
                           placeholder="Введите имена"/>
            <auto-complete id="autoComplete4" query-id="test"
                           value-field-id="id" label-field-id="fio" search-filter-id="fio"
                           placeholder="Введите имена" input-label-field-id="id"/>
            <auto-complete id="autoComplete5" query-id="test" value-field-id="fio">
                <dependencies>
                    <set-value on="autoComplete5">
                        autoComplete5?.filter(({fio}) => (fio !== '123'))
                    </set-value>
                </dependencies>
            </auto-complete>
        </fields>
