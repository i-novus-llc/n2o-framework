<?xml version='1.0' encoding='UTF-8'?>
<page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
      name="Проверка полного удаления элемента мультисета">
    <datasources>
        <datasource id="query" object-id="test"/>
        <datasource id="temp"/>
    </datasources>
    <regions>
        <form id="form" datasource="query">
            <fields>
                <row>
                    <button label="Parent add" validate="false">
                        <set-value to="list">
                            const item = {
                            isNew: true,
                            isEdit: true,
                            inner: [],
                            }
                            return list ? [item, ...list] : [item]
                        </set-value>
                    </button>
                </row>
                <multi-set id="list" can-add="false" can-remove="false" children-label="item {index}">
                    <row>
                        <set ref-id="row" />
                    </row>
                    <row>
                        <col size="2">
                            <button label="add" validate="false" visible="{list[index].isEdit}">
                                <set-value to="list[index].inner">
                                    const item = { }
                                    return list[index].inner ? [...list[index].inner, item] : [item]
                                </set-value>
                            </button>
                        </col>
                        <col size="10">
                            <multi-set id="inner" can-add="false" can-remove="false">
                                <row>
                                    <col size="8">
                                        <set ref-id="row" />
                                    </col>
                                    <button label="remove" validate="false" visible="{list[index].isEdit}">
                                        <set-value to="list[index].inner">
                                            const result = [...list[index].inner]
                                            result.splice($index_1, 1)
                                            return result
                                        </set-value>
                                    </button>
                                </row>
                            </multi-set>
                        </col>
                    </row>
                    <col size="3">
                        <row>
                            <button label="remove" validate="false" visible="{!list[index].isEdit}">
                                <set-value to="list">
                                    const result = [...list]
                                    result.splice(index, 1)
                                    return result
                                </set-value>
                            </button>
                            <button label="edit" validate="false" visible="{!list[index].isEdit}">
                                <set-value to="list[index].isEdit">
                                    true
                                </set-value>
                                <set-value to="editRows">
                                    return {
                                    ...(editRows || {}),
                                    [list[index]['uuid']]: list[index]
                                    }
                                </set-value>
                            </button>
                            <button label="save" validate="false" visible="{list[index].isEdit}">
                                <set-value to="list[index].isEdit">
                                    false
                                </set-value>
                                <set-value to="list[index].isNew">
                                    false
                                </set-value>
                                <set-value  to="editRows">
                                    const temp = { ...editRows }
                                    delete temp[list[index]['uuid']]

                                    return _.isEmpty(temp) ? null : temp
                                </set-value>
                            </button>
                            <button label="cancel" validate="false" visible="{list[index].isEdit}">
                                <if test="list[index].isNew">
                                    <set-value to="list">
                                        const result = [...list]
                                        result.splice(index, 1)
                                        return result
                                    </set-value>
                                </if>
                                <else>
                                    <set-value to="list[index]">
                                        editRows[list[index]['uuid']]
                                    </set-value>
                                    <set-value  to="editRows">
                                        const temp = { ...editRows }
                                        delete temp[list[index]['uuid']]

                                        return _.isEmpty(temp) ? null : temp
                                    </set-value>
                                    <set-value to="list[index].isEdit">
                                        false
                                    </set-value>
                                </else>
                            </button>
                        </row>
                    </col>
                </multi-set>
            </fields>
        </form>
    </regions>
</page>