<?xml version='1.0' encoding='UTF-8'?>
<page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
      name="Тест fetch-on-init">
    <datasources>
        <datasource id="ds1" query-id="test" fetch-on-init="true" size="1"/>
        <inherited-datasource id="ds2"
                              source-datasource="ds1"
                              source-model="datasource">
            <dependencies>
                <fetch on="ds1" model="datasource"/>
            </dependencies>
        </inherited-datasource>
        <datasource id="clientsDs" query-id="test" fetch-on-init="true"/>
        <datasource id="clientsDsCopy"
                    source-datasource="ds1"
                    source-model="resolve"
                    source-field-id="clients">
            <dependencies>
                <copy on="clientsDs"
                      source-model="datasource"
                      target-model="resolve"
                      target-field-id="clients"/>
            </dependencies>
        </datasource>
    </datasources>
    <regions>
        <!-- Тест fetch-on-init с одиночной записью -->
        <form datasource="ds2">
            <fields>
                <input-text id="name"/>
            </fields>
        </form>
        <!-- Тест выполнения <refresh> действия для источника с fetch-on-init="true" -->
        <form datasource="clientsDsCopy">
            <toolbar>
                <button label="Refresh">
                    <refresh datasource="clientsDs"/>
                </button>
            </toolbar>
            <fields>
                <multi-set id="clients">
                    <row>
                        <input-text id="id"/>
                        <input-text id="name"/>
                    </row>
                </multi-set>
            </fields>
        </form>
    </regions>
</page>