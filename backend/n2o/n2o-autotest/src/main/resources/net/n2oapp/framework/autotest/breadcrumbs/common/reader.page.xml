<?xml version='1.0' encoding='UTF-8'?>
<page xmlns="http://n2oapp.net/framework/config/schema/page-4.0">
    <datasources>
        <datasource id="readers" query-id="readers">
            <filters>
                <eq field-id="id" param="id"/>
            </filters>
        </datasource>
    </datasources>
    <regions>
        <table>
            <datasource query-id="books"/>
            <toolbar>
                <button label="Open">
                    <open-page page-id="book" page-name="{name}" route="/:book_id/book">
                        <params>
                            <path-param name="book_id" value="{id}"/>
                        </params>
                    </open-page>
                </button>
            </toolbar>
            <columns>
                <column text-field-id="name"/>
            </columns>
        </table>
    </regions>
</page>