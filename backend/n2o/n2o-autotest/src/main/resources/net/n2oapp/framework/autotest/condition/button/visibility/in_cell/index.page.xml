<?xml version="1.0" encoding="UTF-8"?>
<page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
    name="Страница для автотеста проверяющего условие 'visibility' у кнопок в ячейке">
    <regions>
        <table>
            <datasource id="ds1" query-id="test"/>
            <columns>
                <column text-field-id="name"/>
                <column label="button">
                    <toolbar>
                        <button color="success" label="Button">
                            <dependencies>
                                <visibility>type == 1</visibility>
                            </dependencies>
                        </button>
                    </toolbar>
                </column>
                <column text-field-id="status"/>
                <column>
                    <toolbar>
                        <button label="Завершить"
                                refresh-datasources="ds1"
                                color="success">
                            <invoke operation-id="update" object-id="test">
                                <form-param id="status" value="9"/>
                            </invoke>
                            <dependencies>
                                <visibility>status == 1</visibility>
                            </dependencies>
                        </button>
                    </toolbar>
                </column>
            </columns>
        </table>
    </regions>
</page>
