<?xml version='1.0' encoding='UTF-8'?>
<simple-page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
             name="Тестирование fetch-value на форме">
    <form>
        <fields>
            <input-text id="status" label="Введите id" domain="integer"/>
            <input-text id="name" label="Должно появиться имя">
                <dependencies>
                    <fetch-value query-id="test" on="status" value-field-id="name" apply-on-init="false">
                        <filters>
                            <eq field-id="id" value="{status}"/>
                        </filters>
                    </fetch-value>
                </dependencies>
            </input-text>
            <input-text id="sn" label="Должно появиться имя при id больше 1">
                <dependencies>
                    <fetch-value on="status" apply-on-init="false" query-id="test"
                     value-field-id="name" enabled="{status &gt; 1}">
                        <filters>
                            <eq field-id="id" value="{status}"/>
                        </filters>
                    </fetch-value>
                </dependencies>
            </input-text>
        </fields>
    </form>
</simple-page>