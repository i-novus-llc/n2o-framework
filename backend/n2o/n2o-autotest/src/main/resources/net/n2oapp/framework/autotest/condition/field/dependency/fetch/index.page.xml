<?xml version='1.0' encoding='UTF-8'?>
<simple-page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
             name="Проверка fetch-зависимости у списковых полей">
    <form>
        <datasource id="tableDs" query-id="test" route="/main">
            <filters>
                <eq field-id="id" value="1"/>
            </filters>
        </datasource>
        <fields>
            <input-text id="status"
                        domain="integer"
                        placeholder="Ввести 1, затем 2"
            />

            <radio-group id="radio"
                         label="Фильтр по радио кнопкам"
                         query-id="test"
                         description="При status=1 должно быть 2 значения"
            >
                <filters>
                    <eq field-id="type" value="{status}"/>
                </filters>
                <dependencies>
                    <fetch on="status"/>
                </dependencies>
            </radio-group>
            <checkbox-group id="checkbox" label="Фильтр по чекбоксам"  cache="true" query-id="test"
                            description="При status=1 должно быть 2 значения">
                <filters>
                    <eq field-id="type" value="{status}"/>
                </filters>
                <dependencies>
                    <fetch on="status"/>
                </dependencies>
            </checkbox-group>
            <checkbox-group id="checkbox1" label="Фильтр по чекбоксам с условием доступности fetch"  cache="true" query-id="test"
                            description="При status=1 не должно быть значений, при status=2 должно быть 2 значения">
                <filters>
                    <eq field-id="type" value="{status}"/>
                </filters>
                <dependencies>
                    <fetch on="status" enabled="{status &gt; 1}"/>
                </dependencies>
            </checkbox-group>
        </fields>
    </form>
</simple-page>
