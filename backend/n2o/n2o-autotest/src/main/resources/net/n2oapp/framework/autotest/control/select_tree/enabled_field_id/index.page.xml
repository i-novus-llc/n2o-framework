<?xml version='1.0' encoding='UTF-8'?>
<page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
      name="Проверка недоступности опций при заданом enabled-field-id параметре"
>

    <datasources>
        <datasource id="attributes" query-id="test"/>
    </datasources>

    <regions>
        <form>
            <fields>
                <input-select-tree id="tree1"
                                   parent-field-id="parentKey"
                                   datasource="attributes"
                                   label-field-id="jsonNodeName"
                                   label="Сингл"
                                   max-tag-text-length="30"
                                   enabled-field-id="enabled"
                                   checking-strategy="child"
                                   required="true"
                                   search-filter-id="jsonNodeName"
                />
                <input-select-tree id="tree2"
                                   parent-field-id="parentKey"
                                   datasource="attributes"
                                   label-field-id="jsonNodeName"
                                   label="Мульти"
                                   max-tag-text-length="30"
                                   enabled-field-id="enabled"
                                   checking-strategy="child"
                                   required="true"
                                   search-filter-id="jsonNodeName"
                                   checkboxes="true"
                />
                <input-select-tree id="tree3"
                                   label="Пункты недоступны и выбраны по умолчанию"
                                   datasource="attributes"
                                   parent-field-id="parentKey"
                                   checking-strategy="child"
                                   checkboxes="true"
                                   max-tag-text-length="30"
                                   enabled-field-id="enabled"
                                   label-field-id="jsonNodeName"
                                   search-filter-id="jsonNodeName">
                    <default-values>
                        <value id="211"/>
                        <value id="212"/>
                        <value id="213"/>
                    </default-values>
                </input-select-tree>
            </fields>
        </form>
    </regions>
</page>
