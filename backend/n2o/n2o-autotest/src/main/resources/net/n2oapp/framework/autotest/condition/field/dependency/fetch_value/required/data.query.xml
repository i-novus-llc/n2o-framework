<?xml version='1.0' encoding='UTF-8'?>
<query xmlns="http://n2oapp.net/framework/config/schema/query-5.0">
    <list>
        <test file="data.json"/>
    </list>
    <count>
        <test file="data.json" operation="count"/>
    </count>

    <filters>
        <eq field-id="id" filter-id="id"/>
    </filters>

    <fields>
        <field id="id" domain="integer"/>
        <field id="name"/>
        <field id="value"/>
        <field id="type"/>
    </fields>
</query>
