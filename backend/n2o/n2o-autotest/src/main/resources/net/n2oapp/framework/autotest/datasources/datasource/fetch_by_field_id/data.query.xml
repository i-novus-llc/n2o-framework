<?xml version='1.0' encoding='UTF-8'?>
<query xmlns="http://n2oapp.net/framework/config/schema/query-5.0">
    <list>
        <test file="data.json"/>
    </list>
    <filters>
        <eq filter-id="id" field-id="id"/>
        <eq filter-id="type" field-id="type"/>
        <eq filter-id="org.type" field-id="org.type" mapping="['type']"/>
    </filters>
    <fields>
        <field id="id"/>
        <field id="type"/>
        <field id="name"/>
        <field id="org.type" mapping="['type']"/>
    </fields>
</query>