<?xml version='1.0' encoding='UTF-8'?>
<simple-page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
             name="Тестирование fetch-value на форме">
    <form>
        <datasource query-id="data"/>
        <fields>
            <input-text id="value"/>

            <input-text id="fetchField1" label="Должно появиться имя (сразу)"
                        required="true">
                <dependencies>
                    <fetch-value query-id="data" on="value" size="1"
                                 value-field-id="name">
                        <filters>
                            <eq field-id="id" value="{value}" required="true"/>
                        </filters>
                    </fetch-value>
                </dependencies>
            </input-text>

            <input-text id="fetchField2" label="Должно появиться имя (apply-on-init='false')"
                        required="true">
                <dependencies>
                    <fetch-value query-id="data" on="value" size="1"
                                 value-field-id="name"
                                 apply-on-init="false">
                        <filters>
                            <eq field-id="id" value="{value}" required="true"/>
                        </filters>
                    </fetch-value>
                </dependencies>
            </input-text>
        </fields>
    </form>
</simple-page>