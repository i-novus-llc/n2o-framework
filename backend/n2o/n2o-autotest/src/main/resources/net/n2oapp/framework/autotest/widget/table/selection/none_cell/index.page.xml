<page xmlns="http://n2oapp.net/framework/config/schema/page-4.0">
    <regions>
        <table id="none" selection="none">
            <datasource query-id="test"/>
            <columns>
                <column text-field-id="id"/>
                <column text-field-id="name">
                    <badge/>
                </column>
                <column text-field-id="checkbox">
                    <checkbox enabled="true"/>
                </column>
                <column text-field-id="rating">
                    <rating max="5" readonly="false"/>
                </column>
                <column text-field-id="edit">
                    <edit>
                        <input-text/>
                    </edit>
                </column>
                <column text-field-id="toolbar">
                    <toolbar>
                       <button label="Кнопка">
                           <alert title="alert" placement="topLeft"/>
                       </button>
                    </toolbar>
                </column>
            </columns>
        </table>
    </regions>
</page>