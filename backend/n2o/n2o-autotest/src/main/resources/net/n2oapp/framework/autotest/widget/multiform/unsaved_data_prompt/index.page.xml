<?xml version='1.0' encoding='UTF-8'?>
<simple-page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
             name="Тестирование unsaved-data-prompt для multi-form" route="/">
    <multi-form unsaved-data-prompt="false">
        <datasource id="ds" query-id="test" size="2"/>
        <fields>
            <row>
                <input-text id="name" label="Имя" required="true"/>
            </row>
            <row>
                <col>
                    <button label="Сохранить" color="primary"/>
                    <button label="Удалить" color="danger" validate="false"/>
                </col>
            </row>
        </fields>
        <toolbar place="topLeft">
            <button label="Добавить" color="primary" disable-on-empty-model="false" validate="false">
                <set-value source-model="datasource" target-model="datasource">
                    this ? [{}, ...this] : [{}]
                </set-value>
            </button>
        </toolbar>
    </multi-form>
</simple-page>
