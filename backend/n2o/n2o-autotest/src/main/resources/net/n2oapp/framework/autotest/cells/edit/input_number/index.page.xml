<?xml version="1.0" encoding="UTF-8"?>
<simple-page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
    name="Проверка клика по стрелкам InputNumber в редактируемой ячейке">
    <table>
        <datasource object-id="data" query-id="data"/>
        <actions>
            <action id="update">
                <invoke message-on-success="false" operation-id="update"/>
            </action>
        </actions>
        <columns>
            <column text-field-id="id"/>
            <column label="InputNumber" text-field-id="quantity">
                <edit action-id="update">
                    <input-text id="quantity" domain="integer"/>
                </edit>
            </column>
        </columns>
    </table>
</simple-page>
