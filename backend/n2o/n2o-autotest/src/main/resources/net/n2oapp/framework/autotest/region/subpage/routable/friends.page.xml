<?xml version='1.0' encoding='UTF-8'?>
<page xmlns="http://n2oapp.net/framework/config/schema/page-4.0" name="Подстраница для проверки routable-параметров">

    <datasources>
        <datasource id="friendsDs" query-id="friendsQuery" size="5"/>
    </datasources>

    <regions>
        <table datasource="friendsDs">
            <filters>
                <input-text id="city"/>
            </filters>

            <columns>
                <column text-field-id="id"/>
                <column text-field-id="name"/>
                <column text-field-id="city"/>
                <column text-field-id="age"/>
            </columns>

            <pagination routable="true"/>
        </table>
    </regions>
</page>