<?xml version='1.0' encoding='UTF-8'?>
<page xmlns="http://n2oapp.net/framework/config/schema/page-4.0"
        name="Зависимость fetch источников данных. Срабатывание по изменению указанного поля">
    <regions>
        <form id="ds">
            <fields>
                <input-text id="id"/>
                <input-text id="type"/>
            </fields>
        </form>
        <table>
            <datasource query-id="data">
                <dependencies>
                    <fetch on="ds" field-id="type"/>
                </dependencies>
                <filters>
                    <eq field-id="id" value="{id}" datasource="ds"/>
                    <eq field-id="type" value="{type}" datasource="ds"/>
                </filters>
            </datasource>
            <columns>
                <column text-field-id="id"/>
                <column text-field-id="type"/>
                <column text-field-id="name"/>
            </columns>
        </table>
    </regions>
</page>