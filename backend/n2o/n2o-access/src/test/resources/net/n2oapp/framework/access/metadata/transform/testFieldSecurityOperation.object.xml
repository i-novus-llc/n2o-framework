<?xml version='1.0' encoding='UTF-8'?>
<object xmlns="http://n2oapp.net/framework/config/schema/object-4.0"
        xmlns:sec="http://n2oapp.net/framework/config/schema/security-1.0">
    <operations>
        <operation id="update">
            <in>
                <field id="name"/>
                <field id="salary" sec:roles="hr,admin"/>
                <reference id="org">
                    <field id="name" sec:roles="hr,admin"/>
                </reference>
                <reference id="user" sec:roles="hr,admin">
                    <field id="name" />
                </reference>
                <list id="deps" sec:roles="hr,admin">
                    <field id="name" />
                </list>
                <set id="users" sec:roles="hr,admin">
                    <field id="name" />
                </set>
            </in>
            <out>
                <field id="id"/>
                <field id="secret" sec:permissions="view-sensitive"/>
            </out>
        </operation>
    </operations>
</object>
